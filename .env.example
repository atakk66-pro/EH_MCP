# Copy to .env and fill in. The .env file is gitignored.
#
# Employment Hero OAuth2 app credentials, created in the Developer Portal.
# NOTE: API access requires a Platinum subscription or above.
EH_CLIENT_ID=
EH_CLIENT_SECRET=

# Must match exactly the Redirect URI registered on your EH app. Employment Hero
# requires https; the local sign-in listener serves TLS with a self-signed cert.
EH_REDIRECT_URI=https://127.0.0.1:8765/callback

# Read-only scopes ONLY. Never add a :write scope to this server.
#
# These are the exact scopes configured on the registered app ("NobleCare KPI
# Reader"), copied from its View Application page. EH's scope format is
# resource:action. The app's scope set is immutable, so this must match it.
EH_SCOPES=cost_centres:list employees:list employees:show employees:onboard_polling_status employees_certifications:list employees:leave_balances:list employees:rostered_shifts:job_status employees:rostered_shifts:shift_cost:show employees:timesheet_entries:list employees:work_eligibility:show employing_entities:list leave_categories:list leave_requests:list leave_requests:show pay_categories:list rostered_shifts:list rostered_shifts:show teams:list teams:employees:list work_locations:list work_sites:list work_types:list

# Where the rotating refresh token is stored. Keep this out of git.
EH_TOKEN_FILE=/home/aran/.eh_mcp/token.json

# Endpoints. Override only if Employment Hero changes hosts.
EH_API_BASE=https://api.employmenthero.com
EH_OAUTH_BASE=https://oauth.employmenthero.com
