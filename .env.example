# Copy to .env and fill in. The .env file is gitignored.
#
# Employment Hero OAuth2 app credentials, created in the Developer Portal.
# NOTE: API access requires a Platinum subscription or above.
EH_CLIENT_ID=
EH_CLIENT_SECRET=

# Must match exactly the Redirect URI registered on your EH app.
# If the portal rejects http/localhost, try http://127.0.0.1:8765/callback.
EH_REDIRECT_URI=http://localhost:8765/callback

# Read-only scopes ONLY. Never add a :write scope to this server.
#
# In the Developer Portal "Add New Application" page, tick Read on (scopes are
# immutable once saved, so tick all of these now):
#   Phase 1: Organisations, Employees, Employees certifications, Certifications,
#            Leave requests, Leave categories, Leave balances, Teams,
#            Work locations, Cost centres
#   Phase 2 (hours/overtime, same API): Timesheet entries, Rostered shifts,
#            Pay categories
# Leave unticked: Bank accounts, Documents, Emergency contacts, Pay details,
#   Payslips, Tax declaration, Superannuation, Work eligibility.
#
# The exact scope strings below must match the urn:... identifiers shown on the
# app's Review / detail page. Confirm them there and paste the full list here.
EH_SCOPES=urn:mainapp:organisations:read urn:mainapp:employees:read

# Where the rotating refresh token is stored. Keep this out of git.
EH_TOKEN_FILE=/home/aran/.eh_mcp/token.json

# Endpoints. Override only if Employment Hero changes hosts.
EH_API_BASE=https://api.employmenthero.com
EH_OAUTH_BASE=https://oauth.employmenthero.com
