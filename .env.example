# Copy to .env and fill in. The .env file is gitignored.
#
# Employment Hero OAuth2 app credentials, created in the Developer Portal.
# NOTE: API access requires a Platinum subscription or above.
EH_CLIENT_ID=
EH_CLIENT_SECRET=

# Must match exactly a redirect URI registered on your EH app.
EH_REDIRECT_URI=http://localhost:8765/callback

# Read-only scopes ONLY. Never add a :write scope to this server.
# employees:read is needed only for the employee_count aggregate tool.
EH_SCOPES=urn:mainapp:organisations:read urn:mainapp:employees:read

# Where the rotating refresh token is stored. Keep this out of git.
EH_TOKEN_FILE=/home/aran/.eh_mcp/token.json

# Endpoints. Override only if Employment Hero changes hosts.
EH_API_BASE=https://api.employmenthero.com
EH_OAUTH_BASE=https://oauth.employmenthero.com
